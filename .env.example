# StoryOS Environment Configuration
# Copy to .env and fill in your values

# LLM Provider (openai, anthropic, custom) — 默认使用讯飞星辰（anthropic 协议）
STORYOS_LLM_PROVIDER=anthropic

# API Base URL — 讯飞星辰 Astron Coding Plan
STORYOS_LLM_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/anthropic

# API Key
STORYOS_LLM_API_KEY=your-apikey:apisecret

# Model name — 讯飞星辰统一模型 ID（底层模型在控制台切换）
STORYOS_LLM_MODEL=astron-code-latest

# Notifications (optional)
STORYOS_TELEGRAM_BOT_TOKEN=
STORYOS_TELEGRAM_CHAT_ID=
STORYOS_FEISHU_WEBHOOK_URL=
STORYOS_WECOM_WEBHOOK_URL=
